# OpenClaw — copy to .env or set in PowerShell before running
OPENCLAW_URL=http://127.0.0.1:18790
OPENCLAW_TIMEOUT=180
OPENCLAW_BATCH_SIZE=4
# 1 = skip row-level AI during crawl (fast); rescore separately
OPENCLAW_SKIP_ROW_SCORE=1

WS_GATEWAY_URL=ws://127.0.0.1:18789
WS_GATEWAY_TOKEN=your-gateway-token-from-openclaw.json
WS_GATEWAY_MODEL=deepseek/deepseek-v4-flash
WS_GATEWAY_RESPONSE_TIMEOUT=180
